# API Keys for Fake News Detection App
# Rename this file to .env and fill in your keys before running docker compose

# Groq API Key for LLM models
GROQ_API_KEY=your_groq_api_key_here

# Serper Dev API Key for web search
SERP_DEV_API_KEY=your_serp_dev_api_key_here

# Sarvam AI API Key for translation and speech-to-text
SARVAM_API_KEY=your_sarvam_api_key_here

# imgbb API Key for reverse image search (ImgBB is used to upload images for reverse search)
IMGBB_API_KEY=your_imgbb_api_key_here

# Sightengine API credentials (AI image/video/deepfake detection)
SIGHTENGINE_API_USER=your_sightengine_api_user_here
SIGHTENGINE_API_SECRET=your_sightengine_api_secret_here

# Blockchain bridge API base URL (optional)
BLOCKCHAIN_API_BASE_URL=https://fakensethfa.onrender.com

# Block explorer URL prefix for transaction references in the UI
VITE_BLOCK_EXPLORER_TX_BASE=https://sepolia.etherscan.io/tx/
